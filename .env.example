# Toss Securities Open API credentials
# 발급 후 .env로 복사해서 실제 값을 넣으세요. 텔레그램에 secret을 그대로 보내지 마세요.
TOSSINVEST_CLIENT_ID=your_client_id_here
TOSSINVEST_CLIENT_SECRET=your_client_secret_here
# 계좌/주문 API 호출 시 필요. 먼저 accounts 조회로 확인 가능.
TOSSINVEST_ACCOUNT_SEQ=

# Guarded real-order readiness. 기본값은 비활성화.
# 실전 제출 전에는 config/risk_policy.yaml의 live_trading_enabled도 true여야 하며,
# 코드가 요구하는 정확한 확인 문구도 입력해야 합니다.
TOSSINVEST_LIVE_TRADING_ENABLED=false
TOSSINVEST_LIVE_ORDER_ENDPOINT=
TOSSINVEST_REAL_ORDER_CONFIRMATION="I UNDERSTAND THIS IS A REAL ORDER"
# 선택: 이미 발급받은 access token을 직접 주입할 때만 사용. 비워두면 OAuth token flow 사용.
TOSSINVEST_ACCESS_TOKEN=

# KIS (한국투자증권) Open API credentials
# 실제 값은 로컬 .env에만 넣으세요.
BROKER_PROVIDER=tossinvest
KIS_APP_KEY=
KIS_APP_SECRET=
# 계좌번호를 통으로 쓰거나, 아래 KIS_CANO / KIS_ACNT_PRDT_CD를 분리해서 사용 가능
KIS_ACCOUNT_NO=
KIS_CANO=
KIS_ACNT_PRDT_CD=01
KIS_MOCK_TRADING=false
KIS_LIVE_TRADING_ENABLED=false
KIS_LIVE_ORDER_ENDPOINT=/uapi/domestic-stock/v1/trading/order-cash
KIS_ORDER_TR_ID_BUY=
KIS_ORDER_TR_ID_SELL=
KIS_REAL_ORDER_CONFIRMATION="I UNDERSTAND THIS IS A REAL ORDER"
KIS_ACCESS_TOKEN=
KIS_BASE_URL=
KIS_HASHKEY_ENDPOINT=/uapi/hashkey
